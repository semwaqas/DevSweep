{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevSweep",
  "version": "0.1.0",
  "identifier": "com.devsweep.desktop",
  "build": {
    "beforeDevCommand": "corepack pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "corepack pnpm build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "DevSweep",
        "width": 1280,
        "height": 820,
        "minWidth": 1024,
        "minHeight": 700,
        "backgroundColor": "#edf3fb"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
